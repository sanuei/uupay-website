---
import Layout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import PageHero from '../../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/ui';

const allAnnouncements = await getCollection('announcements');
const sortedAnnouncements = allAnnouncements.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const lang = 'zh-TW';
const t = useTranslations(lang as any);
const base = lang === 'en' ? '' : `/${lang}`;
---

<Layout title="Announcements | UUPAY" lang={lang}>
  <Header lang={lang} />
  <main>
    <PageHero eyebrow={t('nav.announcements')} title={t('nav.announcements')} subtitle={t('announcements.subtitle')} />
    <section class="ann-list container">
      {sortedAnnouncements.length === 0 && <p class="ann-empty">—</p>}
      {sortedAnnouncements.map((post) => (
        <a href={`${base}/announcements/${post.id}`} class="ann-card scroll-reveal">
          <div class="ann-meta">
            <span class="pill pill-ghost">{post.data.type}</span>
            <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
          </div>
          <h2>{post.data.title}</h2>
        </a>
      ))}
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
