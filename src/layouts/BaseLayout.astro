---
import '../styles/global.css';
import '../styles/animations.css';
import '../styles/components.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "UUPAY - 让支付回归简单，让世界触手可达",
  description = "UUPAY 是一款面向全球用户的加密货币金融卡产品，依托 Visa / Mastercard 双卡组织，实现加密资产的全球消费场景落地。",
  lang = "en"
} = Astro.props;

const isRtl = lang === 'ar';
---

<!doctype html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050607" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700;900&display=swap"
    />
  </head>
  <body>
    <!-- 阅读进度条 -->
    <div class="reading-progress" id="reading-progress"></div>

    <slot />

    <script>
      // 给 <html> 加 .js 标记,激活滚动入场初始隐藏
      document.documentElement.classList.add('js');
    </script>

    <!-- 主交互逻辑 (滚动入场 + countUp + 视差 + 立方体旋转 + 截图轮播) -->
    <script>
      // 减少动态效果: 关掉所有 JS 驱动的滚动联动(视差 / pinning),只留 CSS 已处理的淡入
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ============================================
      // 1. Scroll-triggered 入场 (使用 data-anim 而非 class 列表,性能更好)
      // ============================================
      const animObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });

      document.querySelectorAll('.scroll-reveal, .reveal-left, .reveal-right, .reveal-scale').forEach((el) => {
        animObserver.observe(el);
      });

      // ============================================
      // 2. 阅读进度条 (Safari fallback)
      // ============================================
      const progressBar = document.getElementById('reading-progress');
      const updateProgress = () => {
        if (!progressBar) return;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = window.scrollY;
        const progress = docHeight > 0 ? scrolled / docHeight : 0;
        progressBar.style.setProperty('--progress', String(Math.min(progress, 1)));
      };

      // 现代浏览器用 scroll-driven,旧浏览器用 JS 改 --progress
      // 检测是否支持 scroll-driven animation
      const supportsScrollTimeline = CSS.supports?.('animation-timeline', 'scroll()');
      if (!supportsScrollTimeline) {
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
      }

      // ============================================
      // 3. 视差 (Parallax) - 通过 CSS 变量,不直接覆盖 transform
      // ============================================
      if (!prefersReducedMotion) {
        let ticking = false;
        const onScroll = () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const y = window.scrollY;
              document.documentElement.style.setProperty('--scroll-y', `${y}px`);
              ticking = false;
            });
            ticking = true;
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // (Hero 立方体已删除 - 不再需要 mousemove tilt)

      // 实际导航栏高度 (跟 --nav-h 保持同步, 避免硬编码漂移)
      const navH = document.querySelector<HTMLElement>('.navbar')?.offsetHeight || 56;

      // ============================================
      // 5. CARD Pinning - 黑卡主卡(左偏) + 金卡副卡(右倾) 滚动联动
      // ============================================
      const cardPin = document.querySelector<HTMLElement>('.card-pin');
      const cardBlack = document.querySelector<HTMLElement>('.card-3d.black');
      const cardVirtual = document.querySelector<HTMLElement>('.card-3d.virtual');

      if (cardPin && cardBlack && cardVirtual && prefersReducedMotion) {
        // 减少动态效果: 直接展示归位后的静态终态, 不做滚动联动
        cardBlack.style.setProperty('--translate-x', '-280px');
        cardBlack.style.setProperty('--rotate-y', '0deg');
        cardVirtual.style.setProperty('--translate-x', '-40px');
        cardVirtual.style.setProperty('--rotate-y', '0deg');
        cardPin.classList.add('is-pinned');
      } else if (cardPin && cardBlack && cardVirtual) {
        const onCardScroll = () => {
          const rect = cardPin.getBoundingClientRect();
          const vh = window.innerHeight;
          const totalScroll = cardPin.offsetHeight - vh;  // 可滚动距离
          // 计算进度 0~1, 从卡片父容器顶部进入视口到完全离开
          const scrolled = -rect.top + navH;
          const progress = Math.max(0, Math.min(1, scrolled / totalScroll));

          // 阶段 1 (0 → 0.5): 两卡从两侧飞入, 旋转 ±15deg
          // 阶段 2 (0.5 → 1): 两卡归位到主卡 -280px / 副卡 -40px
          const phase1 = Math.min(progress / 0.5, 1);  // 0~1
          const phase2 = Math.max((progress - 0.5) / 0.5, 0);  // 0~1

          // 黑卡(主): 从 -360px 飞到 -280px 归位
          const blackX = -360 + (80 * phase1);
          // 金卡(副): 从 -100px 飞到 -40px 归位
          const virtualX = -100 + (60 * phase1);

          // 旋转: 0° → ±15° → 0°(归位时不旋转)
          const blackAngle = phase1 < 0.5 ? -15 : -15 * (1 - phase2);
          const virtualAngle = phase1 < 0.5 ? 15 : 15 * (1 - phase2);

          cardBlack.style.setProperty('--translate-x', `${blackX}px`);
          cardBlack.style.setProperty('--rotate-y', `${blackAngle}deg`);

          cardVirtual.style.setProperty('--translate-x', `${virtualX}px`);
          cardVirtual.style.setProperty('--rotate-y', `${virtualAngle}deg`);

          // 进入 pinning 时显示连线 + 标签
          if (progress > 0.4) {
            cardPin.classList.add('is-pinned');
          } else {
            cardPin.classList.remove('is-pinned');
          }
        };

        // 用 rAF 节流
        let cardTicking = false;
        const cardScrollHandler = () => {
          if (!cardTicking) {
            requestAnimationFrame(() => {
              onCardScroll();
              cardTicking = false;
            });
            cardTicking = true;
          }
        };
        window.addEventListener('scroll', cardScrollHandler, { passive: true });
        onCardScroll();  // 初始化
      }

      // ============================================
      // 6. STATS Pinning - 3 数字 countUp + 钉住
      // ============================================
      const statsPin = document.querySelector<HTMLElement>('.stats-pin');
      const statsItems = document.querySelectorAll<HTMLElement>('.stats-pin-item');
      const statsProgressBar = document.getElementById('stats-progress-bar');

      if (statsPin && statsItems.length > 0) {
        // 每个数字的目标值
        const statsTargets = Array.from(statsItems).map((el) => ({
          target: parseFloat(el.dataset.target || '0'),
          suffix: el.dataset.suffix || '',
          counted: false
        }));

        const formatNumber = (n: number) => {
          if (n >= 1000) {
            return Math.floor(n).toLocaleString('en-US');
          }
          return Math.floor(n).toString();
        };

        if (prefersReducedMotion) {
          // 减少动态效果: 直接显示最终数值, 不做滚动联动 countUp
          if (statsProgressBar) statsProgressBar.style.transform = 'scaleX(1)';
          statsItems.forEach((item, i) => {
            const counter = item.querySelector('.countup-val');
            const { target, suffix } = statsTargets[i];
            if (counter) counter.textContent = formatNumber(target) + suffix;
            item.classList.add('is-active');
          });
        }

        const onStatsScroll = () => {
          const rect = statsPin.getBoundingClientRect();
          const vh = window.innerHeight;
          const totalScroll = statsPin.offsetHeight - vh;
          const scrolled = -rect.top + navH;
          const progress = Math.max(0, Math.min(1, scrolled / totalScroll));

          // 更新底部进度条
          if (statsProgressBar) {
            statsProgressBar.style.transform = `scaleX(${progress})`;
          }

          // 当前激活段 (0~0.33 = idx 0, 0.33~0.66 = idx 1, 0.66~1 = idx 2)
          const activeIdx = Math.min(Math.floor(progress * 3), 2);

          // 数字 countUp
          statsItems.forEach((item, i) => {
            // 当前段: 0→1 countUp
            // 已过段: 保持终值
            // 未到段: 保持 0
            const counter = item.querySelector('.countup-val');
            if (!counter) return;
            const { target, suffix } = statsTargets[i];

            if (i < activeIdx) {
              // 已过: 直接显示终值
              counter.textContent = formatNumber(target) + suffix;
            } else if (i === activeIdx) {
              // 当前: 段内 0 → 1
              const segStart = i / 3;
              const segEnd = (i + 1) / 3;
              const segProgress = (progress - segStart) / (segEnd - segStart);
              const eased = 1 - Math.pow(1 - Math.min(Math.max(segProgress, 0), 1), 3);
              counter.textContent = formatNumber(target * eased) + suffix;
            } else {
              // 未到: 显示 0
              counter.textContent = '0' + suffix;
            }

            // 当前激活高亮 (active 段 + 之后 0.1 范围内)
            const isActive = i === activeIdx || (i < activeIdx);
            item.classList.toggle('is-active', i <= activeIdx);
          });
        };

        if (!prefersReducedMotion) {
          let statsTicking = false;
          const statsScrollHandler = () => {
            if (!statsTicking) {
              requestAnimationFrame(() => {
                onStatsScroll();
                statsTicking = false;
              });
              statsTicking = true;
            }
          };
          window.addEventListener('scroll', statsScrollHandler, { passive: true });
          onStatsScroll();  // 初始化
        }
      }

      // ============================================
      // 7. APP 截图 - Sticky 切换 (左侧文字滚到中心时切右侧图)
      // ============================================
      const stickySlides = document.querySelectorAll<HTMLElement>('.app-sticky-slide');
      const stickyImgs = document.querySelectorAll<HTMLElement>('.slide-img');

      if (stickySlides.length > 0) {
        const stickyObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && entry.intersectionRatio > 0.4) {
              const idx = (entry.target as HTMLElement).dataset.slideIdx;
              if (idx === undefined) return;
              const i = parseInt(idx, 10);
              stickySlides.forEach((s, j) => s.classList.toggle('is-active', j === i));
              stickyImgs.forEach((m, j) => m.classList.toggle('is-active', j === i));
            }
          });
        }, {
          threshold: [0, 0.4, 0.6],
          rootMargin: '-20% 0px -20% 0px'
        });

        stickySlides.forEach((s) => stickyObserver.observe(s));
      }
    </script>
  </body>
</html>
