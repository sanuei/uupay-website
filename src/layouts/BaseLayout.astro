---
// 自托管字体 (woff2 + unicode-range 分包, 构建时打包进 _astro/)
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/inter/900.css';
// 中文: MiSans (小米, 免费商用, 比 Noto Sans SC 更锐利现代)
// 注意 MiSans 用自家字重值: Regular=330/Medium=380/Semibold=520/Bold=630/Heavy=700
// 浏览器 font-matching 会把站内 400/500/700/900 就近解析到这些档
import 'misans/lib/Normal/MiSans-Regular.min.css';
import 'misans/lib/Normal/MiSans-Medium.min.css';
import 'misans/lib/Normal/MiSans-Semibold.min.css';
import 'misans/lib/Normal/MiSans-Bold.min.css';
import 'misans/lib/Normal/MiSans-Heavy.min.css';
import '../styles/global.css';
import '../styles/animations.css';
import '../styles/components/navbar.css';
import '../styles/components/hero.css';
import '../styles/components/stats.css';
import '../styles/components/features.css';
import '../styles/components/card-showcase.css';
import '../styles/components/app-showcase.css';
import '../styles/components/esim.css';
import '../styles/components/partner.css';
import '../styles/components/promo.css';
import '../styles/components/download.css';
import '../styles/components/faq.css';
import '../styles/components/lifestyle.css';
import '../styles/components/security.css';
import '../styles/components/footer.css';
import '../styles/depth.css';  // 视觉深度系统, 必须最后导入

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "UUPAY - Simplify Payments, Reach the World",
  description = "UUPAY is a next-generation crypto payment platform for global users, powered by Visa & Mastercard virtual and physical cards for real-world crypto spending.",
  lang = "en"
} = Astro.props;

const isRtl = lang === 'ar';

// ===== SEO: hreflang / canonical / OG / Twitter =====
const siteUrl = 'https://uupay.com';
const locales = ['en', 'zh-CN', 'zh-TW', 'ja', 'ko', 'vi', 'th', 'ms', 'id', 'es', 'ar'];

// 去掉当前路径开头的语言前缀 (若有), 得到语言无关的剩余路径, 用于推算各语言对应链接
const pathname = Astro.url.pathname;
const currentPrefix = locales.find((l) => l !== 'en' && (pathname === `/${l}` || pathname.startsWith(`/${l}/`)));
const restPath = currentPrefix ? (pathname.slice(`/${currentPrefix}`.length) || '/') : pathname;
const pathFor = (l: string) => `${l === 'en' ? '' : `/${l}`}${restPath}`;
const urlFor = (l: string) => `${siteUrl}${pathFor(l)}`;
const canonicalUrl = urlFor(lang);

const ogLocaleMap: Record<string, string> = {
  en: 'en_US', 'zh-CN': 'zh_CN', 'zh-TW': 'zh_TW', ja: 'ja_JP', ko: 'ko_KR',
  vi: 'vi_VN', th: 'th_TH', ms: 'ms_MY', id: 'id_ID', es: 'es_ES', ar: 'ar_AR'
};
const ogImage = `${siteUrl}/images/og-cover.jpg`;
---

<!doctype html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050607" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang: 各语言版本互相声明,帮助搜索引擎按用户语言分发正确页面 -->
    {locales.map((l) => (
      <link rel="alternate" hreflang={l} href={urlFor(l)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={urlFor('en')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="UUPAY" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocaleMap[lang] || 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- 词级拆分工具 (Hero 标题 + [data-split] 区块标题共用; 拉丁按词, 中日韩按字,
         每个词/字包 .wmask>.winner, --wi 为 stagger 序号; 保留 .kw 等内联标签) -->
    <script is:inline>
      // st: 跨节点共享状态 { idx: stagger 序号, last: 上一个词的内层 span }
      window.uuSplitWords = function (root, startIdx, st) {
        st = st || { idx: startIdx || 0, last: null };
        var TOKEN = /(\s+|[㐀-䶿一-鿿぀-ヿ가-힯])/;
        var LEAD_PUNCT = /^[,.;:!?%…、。，！？；：）)”’"»]+/;
        var nodes = Array.prototype.slice.call(root.childNodes);
        nodes.forEach(function (node) {
          if (node.nodeType === 3) {
            var text = node.nodeValue;
            if (!text || !text.trim()) return;
            // 行首标点贴到上一个词尾, 防止逗号/句号自成一词掉到行首 (避头尾)
            var lead = text.match(LEAD_PUNCT);
            if (lead && st.last) {
              st.last.textContent += lead[0];
              text = text.slice(lead[0].length);
              if (!text.trim()) { node.nodeValue = text; return; }
            }
            var frag = document.createDocumentFragment();
            text.split(TOKEN).forEach(function (part) {
              if (!part) return;
              if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
              var mask = document.createElement('span');
              mask.className = 'wmask';
              var inner = document.createElement('span');
              inner.className = 'winner';
              inner.style.setProperty('--wi', String(st.idx++));
              inner.textContent = part;
              mask.appendChild(inner);
              frag.appendChild(mask);
              st.last = inner;
            });
            root.replaceChild(frag, node);
          } else if (node.nodeType === 1 && node.tagName !== 'BR') {
            window.uuSplitWords(node, 0, st);
          }
        });
        return st.idx;
      };
    </script>

  </head>
  <body>
    <!-- 阅读进度条 -->
    <div class="reading-progress" id="reading-progress"></div>

    <slot />

    <script>
      // 给 <html> 加 .js 标记,激活滚动入场初始隐藏; .rm 标记 reduced-motion 供 CSS 降级
      document.documentElement.classList.add('js');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('rm');
      }
    </script>

    <!-- 主交互逻辑 (滚动入场 + countUp + 视差 + 立方体旋转 + 截图轮播) -->
    <script>
      import Lenis from 'lenis';

      // 减少动态效果: 关掉所有 JS 驱动的滚动联动(视差 / pinning),只留 CSS 已处理的淡入
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // 移动端(≤968px)没有 sticky/pinning 的视觉空间, 桌面专属的滚动联动不该在移动端空跑
      const isDesktop = window.matchMedia('(min-width: 969px)').matches;
      const enableScrollFx = isDesktop && !prefersReducedMotion;

      // ============================================
      // 0. Lenis 惯性滚动 (Apple/Linear 风格的"有重量感"平滑滚动)
      //    - 只在非 reduced-motion 下启用; 触屏保持原生手感(smoothWheel 只作用于滚轮/触控板)
      //    - Lenis 驱动的是"真实" scrollTop, 所以 position:sticky / IntersectionObserver /
      //      window.scrollY 读取(视差/pin 联动)全部照常工作, 无需改动
      // ============================================
      let lenis: any = null;
      if (!prefersReducedMotion) {
        lenis = new Lenis({
          duration: 1.1,
          // expo-out: 滚一下有初速度, 尾段缓慢收住(惯性感)
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          touchMultiplier: 1.6,
        });

        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);

        // 站内锚点(#products / #cards 等)交给 Lenis 平滑跳转, 带 navbar 高度偏移
        const navEl = document.querySelector<HTMLElement>('.navbar');
        const anchorOffset = -(navEl?.offsetHeight || 64) - 8;
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          const href = a.getAttribute('href');
          if (!href || href.length < 2) return;
          a.addEventListener('click', (e) => {
            const target = document.querySelector(href);
            if (target) {
              e.preventDefault();
              lenis.scrollTo(target, { offset: anchorOffset });
            }
          });
        });
      }

      // ============================================
      // 统一滚动 FX 循环: 所有 scroll 联动(进度条/视差/pin/navbar)
      // 注册进 scrollFx, 共用 1 个 scroll listener + 1 个 rAF,
      // 不再各自监听 scroll 导致一帧内多次强制重排。
      // ============================================
      const scrollFx: Array<() => void> = [];
      let fxTicking = false;
      const runScrollFx = () => {
        for (let i = 0; i < scrollFx.length; i++) scrollFx[i]();
        fxTicking = false;
      };
      window.addEventListener('scroll', () => {
        if (!fxTicking) {
          fxTicking = true;
          requestAnimationFrame(runScrollFx);
        }
      }, { passive: true });

      // ============================================
      // 1. Scroll-triggered 入场 (使用 data-anim 而非 class 列表,性能更好)
      // ============================================
      const animObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });

      document.querySelectorAll('.scroll-reveal, .reveal-clip, .reveal-scale').forEach((el) => {
        animObserver.observe(el);
      });

      // 区块标题词级遮罩入场: 拆词后交给同一个 observer 触发
      const uuSplit = (window as any).uuSplitWords;
      if (!prefersReducedMotion && uuSplit) {
        document.querySelectorAll<HTMLElement>('[data-split]').forEach((el) => {
          uuSplit(el, 0);
          el.classList.add('split-ready');
          animObserver.observe(el);
        });
      }

      // ============================================
      // 2. 阅读进度条 (Safari fallback)
      // ============================================
      const progressBar = document.getElementById('reading-progress');
      const updateProgress = () => {
        if (!progressBar) return;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = window.scrollY;
        const progress = docHeight > 0 ? scrolled / docHeight : 0;
        progressBar.style.setProperty('--progress', String(Math.min(progress, 1)));
      };

      // 现代浏览器用 scroll-driven,旧浏览器用 JS 改 --progress (挂进统一 FX 循环)
      // 检测是否支持 scroll-driven animation
      const supportsScrollTimeline = CSS.supports?.('animation-timeline', 'scroll()');
      if (!supportsScrollTimeline) {
        scrollFx.push(updateProgress);
      }

      // ============================================
      // 3. Navbar 滚动状态: 离顶加深模糊底, 向下滚隐藏/向上滚滑出 (Linear 行为)
      //    移动端菜单打开时禁止隐藏, 避免菜单失去锚点
      // ============================================
      const navbarEl = document.querySelector<HTMLElement>('.navbar');
      if (navbarEl) {
        let lastY = window.scrollY;
        const onNavScroll = () => {
          const y = window.scrollY;
          navbarEl.classList.toggle('is-scrolled', y > 8);
          if (!document.documentElement.classList.contains('nav-open')) {
            navbarEl.classList.toggle('is-hidden', y > lastY && y > 160);
          }
          lastY = y;
        };
        scrollFx.push(onNavScroll);
      }

      // ============================================
      // 4. Hero 视差退场: 视频缓慢放大下沉, 文案上移淡出 (仅桌面端,
      //    让 Hero 到下一区的过渡是"溶过去"而不是"切过去")
      // ============================================
      const heroVideo = document.querySelector<HTMLElement>('.hero-video');
      const heroContent = document.querySelector<HTMLElement>('.hero-content');
      const heroScrollHint = document.querySelector<HTMLElement>('.hero-scroll');
      if (heroVideo && heroContent && enableScrollFx) {
        const onHeroScroll = () => {
          const y = window.scrollY;
          const vh = window.innerHeight;
          if (y > vh * 1.2) return; // 离开首屏后不再计算
          const p = Math.min(1, y / (vh * 0.85));
          heroVideo.style.transform =
            `translate(-50%, calc(-50% + ${(p * 56).toFixed(1)}px)) scale(${(1.15 + p * 0.18).toFixed(3)})`;
          heroContent.style.transform = `translateY(${(-p * 64).toFixed(1)}px)`;
          heroContent.style.opacity = String(1 - p * 0.85);
          if (heroScrollHint) heroScrollHint.style.opacity = String(Math.max(0, 1 - p * 4));
        };
        scrollFx.push(onHeroScroll);
      }

      // (旧的全局 --scroll-y 视差已移除: 唯一消费者是卡片的 parallax-element,
      //  卡片改为横向切换器后不再需要; eSIM 的视差走它自己的相对滚动 handler)

      // 实际导航栏高度 (跟 --nav-h 保持同步, 避免硬编码漂移)
      const navH = document.querySelector<HTMLElement>('.navbar')?.offsetHeight || 56;

      // ============================================
      // 5. eSIM "呼吸段" - 非 pin, 但地球仪跟随滚动做视差 + 缓慢转动,
      //    让这段加高后的自由滚动区不再"一闪而过", 而是从容的过渡
      // ============================================
      const esimSection = document.querySelector<HTMLElement>('.esim');
      const esimVisual = document.querySelector<HTMLElement>('.esim-visual');

      if (esimSection && esimVisual && enableScrollFx) {
        const onEsimScroll = () => {
          const rect = esimSection.getBoundingClientRect();
          const vh = window.innerHeight;
          // 区块中心相对视口中心的偏移, 归一化到 -1(在下方) ~ 1(在上方)
          const sectionCenter = rect.top + rect.height / 2;
          const p = Math.max(-1, Math.min(1, (vh / 2 - sectionCenter) / vh));
          // 地球仪: 轻微反向视差上移 + 跟随滚动转动
          esimVisual.style.setProperty('--esim-parallax', `${(-p * 48).toFixed(1)}px`);
          esimVisual.style.setProperty('--esim-scroll-rot', `${(p * 26).toFixed(1)}deg`);
        };
        scrollFx.push(onEsimScroll);
      }

      // ============================================
      // 6. STATS Pinning - 3 数字 countUp + 钉住
      // ============================================
      const statsPin = document.querySelector<HTMLElement>('.stats-pin');
      const statsItems = document.querySelectorAll<HTMLElement>('.stats-pin-item');
      const statsProgressBar = document.getElementById('stats-progress-bar');

      if (statsPin && statsItems.length > 0) {
        // 每个数字的目标值
        const statsTargets = Array.from(statsItems).map((el) => ({
          target: parseFloat(el.dataset.target || '0'),
          suffix: el.dataset.suffix || '',
          counted: false
        }));

        const formatNumber = (n: number) => {
          if (n >= 1000) {
            return Math.floor(n).toLocaleString('en-US');
          }
          return Math.floor(n).toString();
        };

        if (prefersReducedMotion) {
          // 减少动态效果: 直接显示最终数值, 不做滚动联动 countUp
          if (statsProgressBar) statsProgressBar.style.transform = 'scaleX(1)';
          statsItems.forEach((item, i) => {
            const counter = item.querySelector('.countup-val');
            const { target } = statsTargets[i];
            if (counter) counter.textContent = formatNumber(target);
            item.classList.add('is-active');
          });
        }

        const onStatsScroll = () => {
          const rect = statsPin.getBoundingClientRect();
          const vh = window.innerHeight;
          const totalScroll = statsPin.offsetHeight - vh;
          const scrolled = -rect.top + navH;
          const progress = Math.max(0, Math.min(1, scrolled / totalScroll));

          // 更新底部进度条
          if (statsProgressBar) {
            statsProgressBar.style.transform = `scaleX(${progress})`;
          }

          // 当前激活段 (0~0.33 = idx 0, 0.33~0.66 = idx 1, 0.66~1 = idx 2)
          const activeIdx = Math.min(Math.floor(progress * 3), 2);

          // 数字 countUp
          statsItems.forEach((item, i) => {
            // 当前段: 0→1 countUp
            // 已过段: 保持终值
            // 未到段: 保持 0
            const counter = item.querySelector('.countup-val');
            if (!counter) return;
            const { target } = statsTargets[i];

            if (i < activeIdx) {
              // 已过: 直接显示终值
              counter.textContent = formatNumber(target);
            } else if (i === activeIdx) {
              // 当前: 段内 0 → 1
              const segStart = i / 3;
              const segEnd = (i + 1) / 3;
              const segProgress = (progress - segStart) / (segEnd - segStart);
              const eased = 1 - Math.pow(1 - Math.min(Math.max(segProgress, 0), 1), 3);
              counter.textContent = formatNumber(target * eased);
            } else {
              // 未到: 显示 0
              counter.textContent = '0';
            }

            // 当前激活高亮 (active 段 + 之后 0.1 范围内)
            const isActive = i === activeIdx || (i < activeIdx);
            item.classList.toggle('is-active', i <= activeIdx);
          });
        };

        if (!prefersReducedMotion) {
          scrollFx.push(onStatsScroll);
        }
      }

      // 统一 FX 循环初始化 (navbar 状态 / hero 视差 / eSIM / stats 等首帧就位)
      runScrollFx();

      // ============================================
      // 7. APP 截图 - Sticky 切换 (左侧文字滚到中心时切右侧图)
      // ============================================
      const stickySlides = document.querySelectorAll<HTMLElement>('.app-sticky-slide');
      const stickyImgs = document.querySelectorAll<HTMLElement>('.slide-img');

      // 移动端: 文字区是横向 scroll-snap 轮播, 滑到哪段就切哪张图
      if (!isDesktop && stickySlides.length > 0) {
        const textTrack = document.querySelector<HTMLElement>('.app-sticky-text');
        if (textTrack) {
          let appTicking = false;
          const syncApp = () => {
            const i = Math.max(0, Math.min(stickySlides.length - 1,
              Math.round(textTrack.scrollLeft / textTrack.clientWidth)));
            stickySlides.forEach((s, j) => s.classList.toggle('is-active', j === i));
            stickyImgs.forEach((m, j) => m.classList.toggle('is-active', j === i));
          };
          textTrack.addEventListener('scroll', () => {
            if (!appTicking) {
              requestAnimationFrame(() => { syncApp(); appTicking = false; });
              appTicking = true;
            }
          }, { passive: true });
          syncApp();
        }
      }

      if (isDesktop && stickySlides.length > 0) {
        const stickyObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && entry.intersectionRatio > 0.4) {
              const idx = (entry.target as HTMLElement).dataset.slideIdx;
              if (idx === undefined) return;
              const i = parseInt(idx, 10);
              stickySlides.forEach((s, j) => s.classList.toggle('is-active', j === i));
              stickyImgs.forEach((m, j) => m.classList.toggle('is-active', j === i));
            }
          });
        }, {
          threshold: [0, 0.4, 0.6],
          rootMargin: '-20% 0px -20% 0px'
        });

        stickySlides.forEach((s) => stickyObserver.observe(s));
      }
    </script>
  </body>
</html>
