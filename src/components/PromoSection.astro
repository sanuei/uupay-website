---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
  hideHeader?: boolean;  // 子页面用 PageHero 展示标题时, 隐藏组件自带标题避免重复
}

const { lang, hideHeader = false } = Astro.props;
const t = useTranslations(lang as any);
const base = lang === 'en' ? '' : `/${lang}`;
---

<section class="promos section-glow tr">
  <div class="container">
    {!hideHeader && (
      <div class="section-header">
        <span class="eyebrow scroll-reveal">PROMOTIONS</span>
        <h2 data-split set:html={t('promotions.title_html')} />
        <p class="scroll-reveal">{t('promotions.subtitle')}</p>
      </div>
    )}

    <div class="promos-grid">
      <div class="promo-card solid scroll-reveal stagger-item">
        <span class="promo-badge pulse">HOT</span>
        <div>
          <div class="promo-num">PROMO 01</div>
          <h3>{t('promotions.promo1_title')}</h3>
          <p>{t('promotions.promo1_desc')}</p>
        </div>
        <a href={`${base}/promotions`} class="btn-arrow" style="margin-top: 24px; display: inline-flex;">
          {t('promotions.cta')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
      </div>

      <div class="promo-card outline scroll-reveal stagger-item">
        <span class="promo-badge">NEW</span>
        <div>
          <div class="promo-num">PROMO 02</div>
          <h3>{t('promotions.promo2_title')}</h3>
          <p>{t('promotions.promo2_desc')}</p>
        </div>
        <a href={`${base}/promotions`} class="btn-arrow" style="margin-top: 24px; display: inline-flex;">
          {t('promotions.cta')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
