---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);

// 5 段内容: 每段一个标题 + 描述 + 对应截图 (文案来自 i18n appShowcase.slideN_title/desc)
const slides = [
  { key: 'home', title: t('appShowcase.slide1_title'), desc: t('appShowcase.slide1_desc'), img: '/images/app_home.png' },
  { key: 'card', title: t('appShowcase.slide2_title'), desc: t('appShowcase.slide2_desc'), img: '/images/app_card.png' },
  { key: 'chat', title: t('appShowcase.slide3_title'), desc: t('appShowcase.slide3_desc'), img: '/images/app_chat.png' },
  { key: 'activity', title: t('appShowcase.slide4_title'), desc: t('appShowcase.slide4_desc'), img: '/images/app_activity.png' },
  { key: 'profile', title: t('appShowcase.slide5_title'), desc: t('appShowcase.slide5_desc'), img: '/images/app_profile.png' }
];
---

<section class="app-sticky" id="app-sticky-section">
  <div class="app-sticky-header section-header">
    <span class="eyebrow">APP</span>
    <h2 set:html={t('appShowcase.title_html')} />
    <p>{t('appShowcase.subtitle')}</p>
  </div>

  <!-- 主体:左侧 5 段文字 + 右侧 sticky 大图 -->
  <div class="app-sticky-stage">
    <div class="app-sticky-text">
      {slides.map((slide, i) => (
        <div class={`app-sticky-slide ${i === 0 ? 'is-active' : ''}`} data-slide-idx={i}>
          <div class="slide-eyebrow">0{i + 1} / 0{slides.length}</div>
          <h3 class="slide-title">
            <span class="kw">{slide.title}</span>
          </h3>
          <p class="slide-desc">
            {slide.desc}
          </p>
          <div class="slide-line"></div>
        </div>
      ))}
    </div>

    <div class="app-sticky-phone">
      <div class="phone-frame">
        <div class="phone-screen">
          {slides.map((slide, i) => (
            <img
              src={slide.img}
              alt={slide.title}
              class={`slide-img ${i === 0 ? 'is-active' : ''}`}
              data-img-idx={i}
              width="1179"
              height="2556"
              loading="lazy"
              decoding="async"
            />
          ))}
        </div>
      </div>
      <div class="phone-glow" aria-hidden="true"></div>
    </div>
  </div>
</section>
