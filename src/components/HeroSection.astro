---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
---

<section class="hero">
  <!-- 视频背景层 -->
  <div class="hero-video-wrapper">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/videos/hero_poster.webp"
    >
      <source src="/videos/hero_720p.mp4" type="video/mp4" media="(max-width: 968px)" />
      <source src="/videos/hero_1080p.mp4" type="video/mp4" />
      <!-- 老浏览器 fallback -->
    </video>

    <!-- 双层遮罩: 中心径向透明 → 边缘暗; 顶到底黑色渐变(给文字阅读) -->
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- 视频色调微调 (降饱和 + 降亮度, 让品牌绿更突出) -->
  </div>

  <!-- 几何装饰 - 已删除 (用户要求清爽 hero) -->
  <!-- 只保留视频背景,文字左下角 -->

  <!-- 中心内容 - 改为左下角对齐 -->
  <div class="hero-content">
    <span class="hero-eyebrow">
      <span class="dot"></span>
      <span set:html={t('hero.eyebrow_text')}></span>
    </span>

    <h1 class="hero-title" set:html={t('hero.title_html')}></h1>

    <p class="hero-subtitle">
      {t('hero.subtitle')}
    </p>

    <div class="hero-actions">
      <a href="https://uupay.com/zh-cn/register?invitationCode=VJAIIG" class="btn btn-primary btn-large">
        {t('hero.cta_start')}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#download" class="btn btn-secondary btn-large">
        {t('hero.cta_download')}
      </a>
    </div>
  </div>

  <!-- 滚动提示器 -->
  <div class="hero-scroll" aria-hidden="true">
    <span>SCROLL</span>
    <div class="line">
      <div class="dot"></div>
    </div>
  </div>
</section>

<script>
  // Split-text: 标题按 <br> 拆行, 每行套遮罩逐行升起 (reduced-motion 下不拆)
  const heroTitle = document.querySelector('.hero-title');
  if (heroTitle && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    heroTitle.innerHTML = heroTitle.innerHTML
      .split(/<br\s*\/?>/i)
      .map((l) => `<span class="line-mask"><span class="line-inner">${l}</span></span>`)
      .join('');
    requestAnimationFrame(() => requestAnimationFrame(() => heroTitle.classList.add('is-in')));
  }
</script>
