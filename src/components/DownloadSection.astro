---
import { useTranslations } from '../i18n/ui';
import { siVisa, siMastercard, siTether, siBitcoin, siEthereum, siBnbchain, siBinance } from 'simple-icons';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
const base = lang === 'en' ? '' : `/${lang}`;

const brandLogos = [siVisa, siMastercard, siTether, siBitcoin, siEthereum, siBnbchain, siBinance];
---

<section id="download" class="download">
  <div class="container">
    <div class="download-box scroll-reveal">
      <span class="eyebrow" style="display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px; justify-content: center;">
        <span style="width: 24px; height: 1px; background: var(--brand);"></span>
        DOWNLOAD
        <span style="width: 24px; height: 1px; background: var(--brand);"></span>
      </span>
      <h2>{t('download.title')}</h2>
      <p>{t('download.subtitle')}</p>

      <div class="download-buttons">
        <a
          href="https://apps.apple.com/us/app/uupay-enjoy-global-crypto-trad/id6749419646"
          target="_blank" rel="noopener noreferrer"
          class="download-btn"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.09l.01-.01zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
          </svg>
          <div class="label">
            <span class="small">DOWNLOAD ON</span>
            <span class="big">App Store</span>
          </div>
        </a>

        <a
          href="https://play.google.com/store/apps/details?id=com.uupay.app"
          target="_blank" rel="noopener noreferrer"
          class="download-btn"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893 2.302 2.302-10.937 6.333 8.635-8.635zm3.657-3.657 2.302 2.302a1 1 0 0 1 0 1.414l-2.302 2.302L15.55 12l2.606-2.95zM5.864 2.658 16.8 8.99l-2.302 2.303-8.635-8.635z"/>
          </svg>
          <div class="label">
            <span class="small">GET IT ON</span>
            <span class="big">Google Play</span>
          </div>
        </a>

        <a
          href="https://05dafa.azdmdxwi.com/y8rpvews"
          target="_blank" rel="noopener noreferrer"
          class="download-btn primary"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.523 15.341a.95.95 0 1 1 .002-1.9.95.95 0 0 1-.002 1.9zm-11.046 0a.95.95 0 1 1 .002-1.9.95.95 0 0 1-.002 1.9zm11.388-6.193 1.91-3.307a.42.42 0 0 0-.155-.572.42.42 0 0 0-.572.155l-1.94 3.36C15.402 7.97 13.74 7.5 12 7.5s-3.402.47-5.108 1.284l-1.94-3.36a.42.42 0 0 0-.572-.155.42.42 0 0 0-.155.572l1.91 3.307C3.402 10.5 1.5 13.5 1.5 17h21c0-3.5-1.902-6.5-4.635-7.852z"/>
          </svg>
          <div class="label">
            <span class="small">DIRECT</span>
            <span class="big">Android APK</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="brand-marquee">
  <div class="marquee-track">
    {Array.from({ length: 2 }).map(() => (
      <>
        {brandLogos.map((brand) => (
          <span class="marquee-item">
            <svg class="marquee-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d={brand.path}></path></svg>
            <span class="marquee-label">{brand.title}</span>
          </span>
        ))}
      </>
    ))}
  </div>
</div>
