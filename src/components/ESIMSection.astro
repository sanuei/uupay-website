---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);

// 3 张横向扁卡 (图标 + 短标题 + 说明), 取代原来的带勾列表
const feats = [
  { title: t('esim.feat1_title'), desc: t('esim.desc1'),
    svg: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>' },
  { title: t('esim.feat2_title'), desc: t('esim.desc2'),
    svg: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>' },
  { title: t('esim.feat3_title'), desc: t('esim.desc3'),
    svg: '<path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"/><path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"/>' },
];
---

<section class="esim">
  <div class="container">
    <div class="esim-card scroll-reveal">
      <div class="esim-info">
        <span class="eyebrow" style="display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;">
          <span style="width: 24px; height: 1px; background: var(--brand);"></span>
          eSIM
        </span>
        <h2 set:html={t('esim.title_html')} />
        <p>{t('esim.subtitle')}</p>
        <div class="esim-features">
          {feats.map((f) => (
            <div class="esim-feat scroll-reveal stagger-item">
              <div class="esim-feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={f.svg} />
              </div>
              <div class="esim-feat-body">
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="esim-visual">
        <canvas id="esim-globe" class="esim-globe" aria-hidden="true"></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  import createGlobe from 'cobe';

  const canvas = document.getElementById('esim-globe') as HTMLCanvasElement | null;

  if (canvas) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // 覆盖全球主要城市, 呼应"eSIM 全球覆盖"的营销叙事
    const markers = [
      { location: [22.3193, 114.1694] as [number, number], size: 0.05 }, // 香港
      { location: [1.3521, 103.8198] as [number, number], size: 0.05 },  // 新加坡
      { location: [35.6762, 139.6503] as [number, number], size: 0.05 }, // 东京
      { location: [51.5072, -0.1276] as [number, number], size: 0.05 },  // 伦敦
      { location: [40.7128, -74.006] as [number, number], size: 0.06 },  // 纽约
      { location: [25.2048, 55.2708] as [number, number], size: 0.05 },  // 迪拜
      { location: [-33.8688, 151.2093] as [number, number], size: 0.05 }, // 悉尼
      { location: [-23.5505, -46.6333] as [number, number], size: 0.05 }, // 圣保罗
      { location: [-26.2041, 28.0473] as [number, number], size: 0.04 },  // 约翰内斯堡
      { location: [13.7563, 100.5018] as [number, number], size: 0.04 },  // 曼谷
    ];

    let width = 0;
    let phi = 0;
    let pointerInteracting: number | null = null;
    let pointerInteractionMovement = 0;

    const onResize = () => {
      if (canvas) width = canvas.offsetWidth;
    };
    window.addEventListener('resize', onResize);
    onResize();

    let globe: ReturnType<typeof createGlobe> | null = null;
    try {
      globe = createGlobe(canvas, {
        devicePixelRatio: Math.min(window.devicePixelRatio || 1, 2),
        width: width * 2,
        height: width * 2,
        phi: 0,
        theta: 0.32,
        dark: 1,
        diffuse: 1.2,
        mapSamples: 14000,
        mapBrightness: 5,
        baseColor: [0.35, 0.42, 0.2],
        markerColor: [0.722, 0.89, 0.318],
        glowColor: [0.45, 0.55, 0.25],
        opacity: 0.9,
        markers,
        onRender: (state) => {
          if (pointerInteracting === null && !prefersReducedMotion) {
            phi += 0.0025;
          }
          state.phi = phi + pointerInteractionMovement;
          state.width = width * 2;
          state.height = width * 2;
        },
      });

      requestAnimationFrame(() => {
        canvas.style.opacity = '1';
      });
    } catch {
      // 极少数不支持 WebGL 的环境: 静默隐藏, 不影响其余内容
      canvas.style.display = 'none';
    }

    // 拖拽手动转动地球
    const pointerDown = (e: PointerEvent) => {
      pointerInteracting = e.clientX - pointerInteractionMovement * 200;
      canvas.style.cursor = 'grabbing';
    };
    const pointerUp = () => {
      pointerInteracting = null;
      canvas.style.cursor = 'grab';
    };
    const pointerMove = (e: PointerEvent) => {
      if (pointerInteracting !== null) {
        const delta = e.clientX - pointerInteracting;
        pointerInteractionMovement = delta / 200;
      }
    };

    canvas.addEventListener('pointerdown', pointerDown);
    window.addEventListener('pointerup', pointerUp);
    window.addEventListener('pointermove', pointerMove);
    canvas.addEventListener('pointerleave', pointerUp);
  }
</script>
