---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);

// 3 张横向扁卡 (图标 + 短标题 + 说明), 取代原来的带勾列表
const feats = [
  { title: t('esim.feat1_title'), desc: t('esim.desc1'),
    svg: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>' },
  { title: t('esim.feat2_title'), desc: t('esim.desc2'),
    svg: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>' },
  { title: t('esim.feat3_title'), desc: t('esim.desc3'),
    svg: '<path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"/><path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"/>' },
];
---

<section class="esim">
  <div class="container">
    <div class="esim-card reveal-clip">
      <div class="esim-info">
        <span class="eyebrow" style="display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;">
          <span style="width: 24px; height: 1px; background: var(--brand);"></span>
          eSIM
        </span>
        <h2 data-split set:html={t('esim.title_html')} />
        <p class="scroll-reveal">{t('esim.subtitle')}</p>
        <div class="esim-features">
          {feats.map((f) => (
            <div class="esim-feat scroll-reveal stagger-item">
              <div class="esim-feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={f.svg} />
              </div>
              <div class="esim-feat-body">
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="esim-visual">
        <svg class="esim-globe" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Globe grid: 缓慢自转 -->
          <g class="globe-grid">
            <circle cx="160" cy="160" r="140" stroke="#B8E351" stroke-width="1.5" opacity="0.6"/>
            <ellipse cx="160" cy="160" rx="140" ry="50" stroke="#B8E351" stroke-width="1" opacity="0.4"/>
            <ellipse cx="160" cy="160" rx="140" ry="90" stroke="#B8E351" stroke-width="1" opacity="0.4"/>
            <ellipse cx="160" cy="160" rx="50" ry="140" stroke="#B8E351" stroke-width="1" opacity="0.4"/>
            <ellipse cx="160" cy="160" rx="90" ry="140" stroke="#B8E351" stroke-width="1" opacity="0.4"/>
            <ellipse cx="160" cy="160" rx="120" ry="140" stroke="#B8E351" stroke-width="1" opacity="0.3"/>
          </g>
          <!-- Orbit dots: 呼吸闪烁, 错开延迟 -->
          <g class="orbit-dots">
            <circle class="orbit-dot" cx="20" cy="160" r="4" fill="#B8E351"/>
            <circle class="orbit-dot" cx="300" cy="160" r="4" fill="#B8E351"/>
            <circle class="orbit-dot" cx="160" cy="20" r="4" fill="#B8E351"/>
            <circle class="orbit-dot" cx="160" cy="300" r="4" fill="#B8E351"/>
            <circle class="orbit-dot" cx="60" cy="60" r="3" fill="#B8E351" opacity="0.7"/>
            <circle class="orbit-dot" cx="260" cy="260" r="3" fill="#B8E351" opacity="0.7"/>
            <circle class="orbit-dot" cx="260" cy="60" r="3" fill="#B8E351" opacity="0.7"/>
            <circle class="orbit-dot" cx="60" cy="260" r="3" fill="#B8E351" opacity="0.7"/>
          </g>
        </svg>
      </div>
    </div>
  </div>
</section>
