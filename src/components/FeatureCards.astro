---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
const base = lang === 'en' ? '' : `/${lang}`;
---

<section id="products" class="features">
  <div class="container">
    <div class="section-header scroll-reveal">
      <span class="eyebrow">FEATURES</span>
      <h2 set:html={t('features.title_html')} />
      <p>{t('features.subtitle')}</p>
    </div>

    <div class="features-grid">
      <!-- 1. U 卡: 亮绿实底卡 -->
      <div class="feature-card solid scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
            </svg>
          </div>
          <h3>{t('features.card1_title')}</h3>
          <p>{t('features.card1_desc')}</p>
        </div>
        <span class="feature-arrow">
          {t('features.card1_cta')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>

      <!-- 2. eSIM: 暗色细描边卡 -->
      <div class="feature-card outline scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="2" width="12" height="20" rx="2"/><rect x="9.5" y="8" width="5" height="4.5" rx="1"/><line x1="11" y1="18" x2="13" y2="18"/>
            </svg>
          </div>
          <h3>{t('features.card2_title')}</h3>
          <p>{t('features.card2_desc')}</p>
        </div>
        <span class="feature-arrow">
          {t('features.card2_cta')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>

      <!-- 3. 机酒预定: 亮绿实底卡 -->
      <div class="feature-card solid scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.8 19.2 16 11l3.5-3.5a2.12 2.12 0 0 0-3-3L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
            </svg>
          </div>
          <h3>{t('features.card3_title')}</h3>
          <p>{t('features.card3_desc')}</p>
        </div>
        <span class="feature-arrow">
          {t('features.card3_cta')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>

      <!-- 4. 聊天转账: 暗色细描边卡 -->
      <div class="feature-card outline scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/><line x1="8" y1="10" x2="8.01" y2="10"/><line x1="12" y1="10" x2="12.01" y2="10"/><line x1="16" y1="10" x2="16.01" y2="10"/>
            </svg>
          </div>
          <h3>{t('features.card4_title')}</h3>
          <p>{t('features.card4_desc')}</p>
        </div>
        <span class="feature-arrow">
          {t('features.card4_cta')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>
    </div>
  </div>
</section>
