---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
const base = lang === 'en' ? '' : `/${lang}`;
---

<section id="products" class="features">
  <div class="container">
    <div class="section-header scroll-reveal">
      <span class="eyebrow">FEATURES</span>
      <h2>释放<span class="kw">加密货币</span>的真正力量</h2>
      <p>{t('features.subtitle')}</p>
    </div>

    <div class="features-grid">
      <!-- 1. U 卡: 亮绿实底卡 -->
      <div class="feature-card solid scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5">
              <rect x="6" y="12" width="44" height="32" rx="4"/>
              <rect x="6" y="18" width="44" height="6" fill="currentColor"/>
              <line x1="14" y1="32" x2="22" y2="32"/>
              <line x1="14" y1="36" x2="20" y2="36"/>
              <circle cx="42" cy="35" r="4" fill="currentColor"/>
            </svg>
          </div>
          <h3>{t('features.card1_title')}</h3>
          <p>{t('features.card1_desc')}</p>
        </div>
        <span class="feature-arrow">
          {lang === 'zh-CN' || lang === 'zh-TW' ? '了解 U 卡' : 'Explore U-Card'}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>

      <!-- 2. eSIM: 暗色细描边卡 -->
      <div class="feature-card outline scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5">
              <rect x="16" y="10" width="24" height="36" rx="3"/>
              <line x1="22" y1="16" x2="34" y2="16"/>
              <rect x="22" y="24" width="12" height="10" rx="1"/>
              <line x1="26" y1="40" x2="30" y2="40"/>
              <circle cx="44" cy="18" r="3" fill="currentColor"/>
            </svg>
          </div>
          <h3>{t('features.card2_title')}</h3>
          <p>{t('features.card2_desc')}</p>
        </div>
        <span class="feature-arrow">
          {lang === 'zh-CN' || lang === 'zh-TW' ? '了解 eSIM' : 'Explore eSIM'}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>

      <!-- 3. 大额出金: 亮绿实底卡 -->
      <div class="feature-card solid scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5">
              <path d="M28 6 L46 14 V32 C46 42 38 48 28 52 C18 48 10 42 10 32 V14 Z"/>
              <path d="M20 28 L26 34 L38 22"/>
            </svg>
          </div>
          <h3>{t('features.card3_title')}</h3>
          <p>{t('features.card3_desc')}</p>
        </div>
        <span class="feature-arrow">
          {lang === 'zh-CN' || lang === 'zh-TW' ? '了解出金' : 'Explore Withdrawals'}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>

      <!-- 4. 聊天转账: 暗色细描边卡 -->
      <div class="feature-card outline scroll-reveal stagger-item">
        <div>
          <div class="feature-icon">
            <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5">
              <path d="M8 12 C8 9 10 8 12 8 H44 C46 8 48 9 48 12 V36 C48 39 46 40 44 40 H24 L14 50 V40 H12 C10 40 8 39 8 36 Z"/>
              <circle cx="20" cy="24" r="2" fill="currentColor"/>
              <circle cx="28" cy="24" r="2" fill="currentColor"/>
              <circle cx="36" cy="24" r="2" fill="currentColor"/>
            </svg>
          </div>
          <h3>{t('features.card4_title')}</h3>
          <p>{t('features.card4_desc')}</p>
        </div>
        <span class="feature-arrow">
          {lang === 'zh-CN' || lang === 'zh-TW' ? '了解聊天转账' : 'Explore Chat & Pay'}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
      </div>
    </div>
  </div>
</section>
