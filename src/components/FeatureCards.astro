---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
const base = lang === 'en' ? '' : `/${lang}`;

// 帮助中心(Intercom)只提供这 6 种语言, 站内其余语言兜底到英文 (与 Footer 帮助中心链接逻辑一致)
const helpLocales = ['en', 'zh-CN', 'zh-TW', 'ja', 'th', 'es'];
const helpLang = helpLocales.includes(lang) ? lang : 'en';
const helpBase = `https://help.uupay.com/${helpLang}`;

// 帮助中心分类 slug: 目前只confirmed 中/英文 slug, 其余语言(zh-TW/ja/th/es)暂沿用英文 slug
const helpSlugs = {
  cards: { 'zh-CN': '18455593-管理卡', en: '18455593-manage-cards' },
  esim: { 'zh-CN': '18397238-esim', en: '18397238-esim' },
  orders: { 'zh-CN': '18455590-管理交易订单', en: '18455590-order-management' },
};

function helpCollection(key: keyof typeof helpSlugs) {
  const slug = helpSlugs[key][helpLang === 'zh-CN' ? 'zh-CN' : 'en'];
  return `${helpBase}/collections/${slug}`;
}

// 机酒预定暂无对应帮助中心分类, 兜底到帮助中心首页
const helpHome = `${helpBase}/`;
---

<section id="products" class="features">
  <div class="container">
    <div class="section-header scroll-reveal">
      <span class="eyebrow">FEATURES</span>
      <h2 set:html={t('features.title_html')} />
      <p>{t('features.subtitle')}</p>
    </div>

    <div class="features-grid" id="features-grid">
      <!-- 1. U 卡: 亮绿实底卡 + 真机卡片照片 (悬浮上浮 + 光泽扫过) -->
      <a href={helpCollection('cards')} target="_blank" rel="noopener noreferrer" class="feature-card solid scroll-reveal stagger-item">
        <div class="feature-visual fv-card">
          <img src="/images/card-black.webp" alt="" width="900" height="567" loading="lazy" decoding="async" class="fv-card-img" />
          <span class="fv-card-glare" aria-hidden="true"></span>
        </div>
        <div class="feature-content">
          <h3>{t('features.card1_title')}</h3>
          <p>{t('features.card1_desc')}</p>
          <span class="feature-arrow">
            {t('features.card1_cta')}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
        </div>
      </a>

      <!-- 2. eSIM: 暗色细描边卡 + 信号波纹图形 -->
      <a href={helpCollection('esim')} target="_blank" rel="noopener noreferrer" class="feature-card outline scroll-reveal stagger-item">
        <div class="feature-visual fv-esim" aria-hidden="true">
          <span class="fv-esim-grid"></span>
          <span class="fv-ring"></span>
          <span class="fv-ring"></span>
          <span class="fv-ring"></span>
          <span class="fv-esim-core">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="2" width="12" height="20" rx="2"/><rect x="9.5" y="8" width="5" height="4.5" rx="1"/><line x1="11" y1="18" x2="13" y2="18"/>
            </svg>
          </span>
          <span class="fv-pin fv-pin-1"></span>
          <span class="fv-pin fv-pin-2"></span>
          <span class="fv-pin fv-pin-3"></span>
        </div>
        <div class="feature-content">
          <h3>{t('features.card2_title')}</h3>
          <p>{t('features.card2_desc')}</p>
          <span class="feature-arrow">
            {t('features.card2_cta')}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
        </div>
      </a>

      <!-- 3. 机酒预定: 亮绿实底卡 + 航线飞行图形 (帮助中心暂无对应分类, 兜底首页) -->
      <a href={helpHome} target="_blank" rel="noopener noreferrer" class="feature-card solid scroll-reveal stagger-item">
        <div class="feature-visual fv-travel" aria-hidden="true">
          <svg class="fv-travel-svg" viewBox="0 0 220 130" fill="none">
            <path class="fv-route" d="M26 104 Q110 6 194 62" stroke="currentColor" stroke-width="2" stroke-dasharray="4 6" stroke-linecap="round"/>
            <circle class="fv-node" cx="26" cy="104" r="5"/>
            <circle class="fv-node" cx="194" cy="62" r="5"/>
            <g class="fv-plane">
              <path d="M12 2 22 2 15 9 22 22 18 22 10 12 4 12 2 16 0 16 1 9 0 2 2 2 4 6 10 6Z" transform="translate(-11,-12) scale(0.9)"/>
            </g>
          </svg>
        </div>
        <div class="feature-content">
          <h3>{t('features.card3_title')}</h3>
          <p>{t('features.card3_desc')}</p>
          <span class="feature-arrow">
            {t('features.card3_cta')}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
        </div>
      </a>

      <!-- 4. 聊天转账: 暗色细描边卡 + 聊天气泡 + 飞行代币 -->
      <a href={helpCollection('orders')} target="_blank" rel="noopener noreferrer" class="feature-card outline scroll-reveal stagger-item">
        <div class="feature-visual fv-chat" aria-hidden="true">
          <span class="fv-bubble fv-bubble-l">
            <i></i><i></i>
          </span>
          <span class="fv-bubble fv-bubble-r">
            <i></i><i></i>
          </span>
          <span class="fv-coin">₮</span>
        </div>
        <div class="feature-content">
          <h3>{t('features.card4_title')}</h3>
          <p>{t('features.card4_desc')}</p>
          <span class="feature-arrow">
            {t('features.card4_cta')}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
        </div>
      </a>
    </div>

    <!-- 移动端专属: 圆点指示器, 与横向滑动的卡片同步 -->
    <div class="features-dots" id="features-dots">
      {[0, 1, 2, 3].map((i) => (
        <button class={`features-dot ${i === 0 ? 'is-active' : ''}`} data-idx={i} aria-label={`Feature ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<script>
  // 移动端: 横向滑动的卡片 <-> 底部圆点 双向同步
  const grid = document.getElementById('features-grid');
  const dotsWrap = document.getElementById('features-dots');

  if (grid && dotsWrap) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.feature-card'));
    const dots = Array.from(dotsWrap.querySelectorAll<HTMLElement>('.features-dot'));
    const isMobile = () => window.matchMedia('(max-width: 968px)').matches;

    let ticking = false;
    const sync = () => {
      if (!isMobile() || cards.length === 0) return;
      const target = grid.scrollLeft;
      let nearest = 0;
      let best = Infinity;
      cards.forEach((c, i) => {
        const d = Math.abs(c.offsetLeft - target);
        if (d < best) { best = d; nearest = i; }
      });
      dots.forEach((d, i) => d.classList.toggle('is-active', i === nearest));
    };

    grid.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { sync(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });

    dots.forEach((d) => {
      d.addEventListener('click', () => {
        const i = Number(d.dataset.idx);
        const card = cards[i];
        if (card) grid.scrollTo({ left: card.offsetLeft, behavior: 'smooth' });
      });
    });

    window.addEventListener('resize', sync);
    sync();
  }
</script>
